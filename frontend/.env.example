# Relative by default since nginx serves the API and this SPA from the same
# origin. Only needed if the frontend and API are ever split across domains.
# NUXT_PUBLIC_API_BASE=/api

# Displayed app name (app bar + auth screens). Baked in at build/generate time.
# NUXT_PUBLIC_APP_NAME=LarNux

# Tagline shown under the brand. Baked in at build/generate time.
# NUXT_PUBLIC_APP_TAGLINE=Boilerplate for building Laravel + Nuxt apps
