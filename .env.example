# Docker Compose-level variables only — NOT read by the apps themselves.
# Laravel reads backend/.env, Nuxt reads frontend/.env (see their own
# .env.example files). Keep the DB_* values below in sync with backend/.env.

APP_PORT=80

# Mailpit web inbox (local mail catcher, dev only) — http://localhost:8025
MAILPIT_PORT=8025

# MinIO local S3-compatible storage (dev only). API on MINIO_API_PORT, web
# console on MINIO_CONSOLE_PORT (http://localhost:9001, login below). The
# credentials must match backend/.env's AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
