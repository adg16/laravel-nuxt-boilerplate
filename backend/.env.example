APP_NAME="LarNux"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
# Default filesystem disk — also where profile avatars are stored. `s3` targets
# the local MinIO container (docker-compose.override.yml); use `local` for
# on-disk storage, or keep `s3` with real AWS creds in production.
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# Local dev sends to the Mailpit catcher (docker-compose.override.yml); read the
# inbox at http://localhost:8025. In production, set real SMTP credentials.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 disk — pointed at the local MinIO container in dev. In production, replace
# with real AWS credentials, drop AWS_ENDPOINT, and set AWS_USE_PATH_STYLE=false.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=larnux
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# SPA / Sanctum
FRONTEND_URLS=http://localhost
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Seeded by database/seeders/DatabaseSeeder.php (php artisan db:seed).
# DEFAULT_USER_NAME is also a reserved display name — no other account may use it.
DEFAULT_USER_NAME="Super Admin"
DEFAULT_USER_EMAIL=super.admin@example.com
DEFAULT_USER_PASSWORD=password
# The permission-less "System" service account used to attribute app-generated
# activity (scheduled/automated events). Has no usable password — cannot log in.
# SYSTEM_USER_NAME is also a reserved display name — no other account may use it.
SYSTEM_USER_NAME=System
SYSTEM_USER_EMAIL=system@example.com

# Default for the `user_creation_mode` setting (editable at runtime from the
# Settings UI): choice | invite | set_password. `choice` lets the admin pick
# per user; the others force one path.
USER_CREATION_MODE=choice
